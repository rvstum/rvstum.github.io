{
  "compilerOptions": {
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "resolveJsonModule": true,
    "jsx": "preserve",
    "allowSyntheticDefaultImports": true,
    "jsxFactory": "h",
    "jsxFragmentFactory": "Fragment",
    "paths": {
      "#imports": [
        "./types/nitro-imports"
      ],
      "~/*": [
        "../*"
      ],
      "@/*": [
        "../*"
      ],
      "~~/*": [
        "../*"
      ],
      "@@/*": [
        "../*"
      ],
      "@unhead/vue": [
        "../node_modules/@unhead/vue"
      ],
      "@nuxt/devtools": [
        "../node_modules/@nuxt/devtools"
      ],
      "vue": [
        "../node_modules/vue"
      ],
      "@vue/runtime-core": [
        "../node_modules/@vue/runtime-core"
      ],
      "@vue/compiler-sfc": [
        "../node_modules/@vue/compiler-sfc"
      ],
      "vue-router": [
        "../node_modules/vue-router"
      ],
      "vue-router/auto-routes": [
        "../node_modules/vue-router/vue-router-auto-routes"
      ],
      "unplugin-vue-router/client": [
        "../node_modules/unplugin-vue-router/client"
      ],
      "@nuxt/schema": [
        "../node_modules/nuxt/node_modules/@nuxt/schema"
      ],
      "nuxt": [
        "../node_modules/nuxt"
      ],
      "vite/client": [
        "../node_modules/vite/client"
      ],
      "nitropack/types": [
        "../node_modules/nitropack/types"
      ],
      "nitropack/runtime": [
        "../node_modules/nitropack/runtime"
      ],
      "nitropack": [
        "../node_modules/nitropack"
      ],
      "defu": [
        "../node_modules/defu"
      ],
      "h3": [
        "../node_modules/h3"
      ],
      "consola": [
        "../node_modules/consola"
      ],
      "ofetch": [
        "../node_modules/ofetch"
      ],
      "crossws": [
        "../node_modules/crossws"
      ],
      "#shared": [
        "../shared"
      ],
      "#shared/*": [
        "../shared/*"
      ],
      "assets": [
        "../assets"
      ],
      "assets/*": [
        "../assets/*"
      ],
      "public": [
        "../public"
      ],
      "public/*": [
        "../public/*"
      ],
      "#server": [
        "../server"
      ],
      "#server/*": [
        "../server/*"
      ],
      "#build": [
        "./"
      ],
      "#build/*": [
        "./*"
      ],
      "#internal/nuxt/paths": [
        "../node_modules/@nuxt/nitro-server/dist/runtime/utils/paths"
      ],
      "#og-image": [
        "../node_modules/nuxt-og-image/dist/runtime"
      ],
      "#og-image/*": [
        "../node_modules/nuxt-og-image/dist/runtime/*"
      ],
      "#og-image-cache": [
        "../node_modules/nuxt-og-image/dist/runtime/server/og-image/cache/lru"
      ],
      "#nuxt-og-image-utils": [
        "../node_modules/nuxt-og-image/dist/runtime/shared"
      ],
      "#site-config": [
        "../node_modules/nuxt-site-config/dist/runtime"
      ],
      "#site-config/*": [
        "../node_modules/nuxt-site-config/dist/runtime/*"
      ],
      "#unhead/composables": [
        "../node_modules/nuxt/dist/head/runtime/composables/v3"
      ],
      "#internal/nuxt-site-config": [
        "../node_modules/nuxt-site-config/dist/runtime/server/composable-barrel-deprecated"
      ],
      "#og-image/renderers/satori": [
        "../node_modules/nuxt-og-image/dist/runtime/server/og-image/satori/renderer"
      ],
      "#og-image/renderers/chromium": [
        "../node_modules/nuxt-og-image/dist/runtime/server/og-image/chromium/renderer"
      ],
      "#og-image/bindings/css-inline": [
        "../node_modules/nuxt-og-image/dist/runtime/mock/empty"
      ],
      "#og-image/bindings/sharp": [
        "../node_modules/nuxt-og-image/dist/runtime/mock/empty"
      ],
      "#og-image/bindings/resvg": [
        "../node_modules/nuxt-og-image/dist/runtime/server/og-image/bindings/resvg/node"
      ],
      "#og-image/bindings/satori": [
        "../node_modules/nuxt-og-image/dist/runtime/server/og-image/bindings/satori/node"
      ],
      "#og-image/bindings/chromium": [
        "../node_modules/nuxt-og-image/dist/runtime/server/og-image/bindings/chromium/playwright"
      ],
      "electron": [
        "../node_modules/nuxt-og-image/dist/runtime/mock/proxy-cjs"
      ],
      "bufferutil": [
        "../node_modules/nuxt-og-image/dist/runtime/mock/proxy-cjs"
      ],
      "utf-8-validate": [
        "../node_modules/nuxt-og-image/dist/runtime/mock/proxy-cjs"
      ],
      "queue": [
        "../node_modules/nuxt-og-image/dist/runtime/mock/proxy-cjs"
      ],
      "chromium-bidi": [
        "../node_modules/nuxt-og-image/dist/runtime/mock/proxy-cjs"
      ]
    },
    "lib": [
      "esnext",
      "webworker",
      "dom.iterable"
    ],
    "noUncheckedIndexedAccess": true,
    "allowArbitraryExtensions": true
  },
  "include": [
    "./types/nitro-nuxt.d.ts",
    "../node_modules/nuxt-site-config/dist/runtime/server",
    "../node_modules/nuxt-site-config/dist/dist/runtime/server",
    "../node_modules/runtime/server",
    "../node_modules/dist/runtime/server",
    "../server/**/*",
    "../shared/**/*.d.ts",
    "./types/nitro.d.ts",
    "../**/*"
  ],
  "exclude": [
    "../node_modules",
    "../node_modules/nuxt/node_modules",
    "../node_modules/nuxt-site-config/node_modules",
    "../node_modules/nuxt-og-image/node_modules",
    "../node_modules/@nuxt/telemetry/node_modules",
    "../dist"
  ]
}